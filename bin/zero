#!/usr/bin/env bash
# bin/zero — main CLI for zero / mail-triage
set -euo pipefail

# Resolve repo root from this script's location, then source config.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../config.sh
source "$SCRIPT_DIR/../config.sh"

# gws uses per-account keyring creds; a stray GOOGLE_WORKSPACE_CLI_TOKEN (often
# exported from a shell profile) is read as the access token and breaks every call.
unset GOOGLE_WORKSPACE_CLI_TOKEN

SUBCOMMAND="${1:-}"

case "$SUBCOMMAND" in

  app)
    APP_BUNDLE="$MAIL_TRIAGE_DIR/macapp/build/zero.app"
    if [ ! -d "$APP_BUNDLE" ]; then
      echo "Building zero.app (first run)..."
      bash "$MAIL_TRIAGE_DIR/macapp/build.sh"
    fi
    echo "Opening $APP_BUNDLE"
    open "$APP_BUNDLE"
    ;;

  run)
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file

    # Read grace_days from app/settings.json (fallback 0) so scheduled runs honor the UI setting.
    GRACE_DAYS=$("$MAIL_TRIAGE_PYTHON" -c '
import json, os, sys
settings_path = os.path.join(os.path.dirname(sys.argv[1]), "app", "settings.json")
try:
    g = json.load(open(settings_path)).get("grace_days", 0)
except Exception:
    g = 0
print(int(g))
' "$MAIL_TRIAGE_ACCOUNTS" 2>/dev/null || echo 0)

    # Parse accounts.json (list OR {"accounts":[...]}) and run the keeper per account.
    # Only include accounts where enabled != false (backward-compatible default: enabled).
    accounts=$("$MAIL_TRIAGE_PYTHON" -c '
import json, sys
data = json.load(open(sys.argv[1]))
accts = data if isinstance(data, list) else data.get("accounts", [])
for a in accts:
    if a.get("enabled", True) is False:
        continue
    print("\t".join([a["config_dir"], a.get("email", a.get("slug", "")),
                     a.get("slug", a.get("email", ""))]))
' "$MAIL_TRIAGE_ACCOUNTS")

    total_aside=0; total_kept=0
    while IFS=$'\t' read -r config_dir email slug; do
      [ -z "$config_dir" ] && continue
      echo "--- Running keeper pass for: $slug ($email) ---"
      acct_out=$("$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/review_open_loops.py" \
        "$config_dir" "$email" --grace-days "$GRACE_DAYS" --execute)
      printf '%s\n' "$acct_out"
      # Sum the per-account result line (same keys keeper_server reads) for the notification.
      counts=$(printf '%s\n' "$acct_out" | "$MAIL_TRIAGE_PYTHON" -c '
import sys, json
lines = [l for l in sys.stdin if l.strip().startswith("{")]
d = json.loads(lines[-1]) if lines else {}
print(int(d.get("to_archive_threads", 0) or 0), int(d.get("to_keep_threads", 0) or 0))
' 2>/dev/null || echo "0 0")
      set -- $counts
      total_aside=$((total_aside + ${1:-0}))
      total_kept=$((total_kept + ${2:-0}))
    done <<< "$accounts"

    echo "--- Learning from recent actions ---"
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/learn.py" || true

    echo "--- Refreshing dashboard state ---"
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/dashboard_state.py"

    # Queue a native 'run complete' notification (honors notify_on_run).
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/notify_run.py" "$total_aside" "$total_kept" || true
    echo "Done."
    ;;

  state)
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file
    echo "Refreshing dashboard state..."
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/dashboard_state.py"
    echo "Done."
    ;;

  stop)
    if pkill -f keeper_server.py 2>/dev/null; then
      echo "Stopped keeper_server.py."
    else
      echo "No running keeper_server.py found."
    fi
    ;;

  schedule)
    # Install a LaunchAgent. Reads schedule settings from app/settings.json if present.
    # Hour can be overridden as arg 2 (default 7) for quick CLI install.
    HOUR="${2:-}"
    LABEL="com.drewl.zero.daily"
    PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
    mkdir -p "$HOME/Library/LaunchAgents" "$MAIL_TRIAGE_LOGS"
    # Generate plist via Python so schedule_days produces the correct <array> shape
    # (consistent with keeper_server._rewrite_schedule_plist). Prints HH:MM to stdout.
    SCHEDULE_TIME=$("$MAIL_TRIAGE_PYTHON" - \
        "$MAIL_TRIAGE_ACCOUNTS" "$SCRIPT_DIR/zero" "$PLIST" "$MAIL_TRIAGE_LOGS" "$HOUR" <<'PYEOF'
import json, os, sys
accounts_path, zero_bin, plist_path, logs_dir, hour_override = sys.argv[1:]
settings_path = os.path.join(os.path.dirname(accounts_path), "app", "settings.json")
try:
    s = json.load(open(settings_path))
except Exception:
    s = {}
hour   = int(hour_override) if hour_override else int(s.get("schedule_hour", 7))
minute = int(s.get("schedule_minute", 0))
days   = s.get("schedule_days", [1, 2, 3, 4, 5])
if days:
    interval_entries = "\n".join(
        f"    <dict><key>Weekday</key><integer>{d}</integer>"
        f"<key>Hour</key><integer>{hour}</integer>"
        f"<key>Minute</key><integer>{minute}</integer></dict>"
        for d in days
    )
    start_interval = f"  <key>StartCalendarInterval</key>\n  <array>\n{interval_entries}\n  </array>"
else:
    start_interval = (f"  <key>StartCalendarInterval</key>\n"
                      f"  <dict><key>Hour</key><integer>{hour}</integer>"
                      f"<key>Minute</key><integer>{minute}</integer></dict>")
label = "com.drewl.zero.daily"
xml = f"""<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>{label}</string>
  <key>ProgramArguments</key>
  <array>
    <string>{zero_bin}</string>
    <string>run</string>
  </array>
{start_interval}
  <key>EnvironmentVariables</key>
  <dict><key>GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND</key><string>file</string></dict>
  <key>StandardOutPath</key><string>{logs_dir}/daily.out.log</string>
  <key>StandardErrorPath</key><string>{logs_dir}/daily.err.log</string>
</dict>
</plist>
"""
open(plist_path, "w").write(xml)
print(f"{hour:02d}:{minute:02d}")
PYEOF
    )
    launchctl unload "$PLIST" 2>/dev/null || true
    if launchctl load -w "$PLIST" 2>/dev/null; then
      echo "Scheduled: the keeper runs at $SCHEDULE_TIME on configured days. Logs in $MAIL_TRIAGE_LOGS."
    else
      echo "Wrote $PLIST but couldn't load it; run: launchctl load -w \"$PLIST\""
    fi
    ;;

  unschedule)
    LABEL="com.drewl.zero.daily"
    PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
    launchctl unload "$PLIST" 2>/dev/null || true
    rm -f "$PLIST"
    echo "Unscheduled the daily keeper."
    ;;

  *)
    cat <<'USAGE'
zero — keep every inbox at "only what needs you"

Usage:
  zero app           Build (if needed) and open the native menu-bar app
  zero run           Run the keeper across all accounts, then refresh state
  zero state         Refresh the app's cached state without opening anything
  zero schedule [H]  Run the keeper automatically every morning (hour H, default 7)
  zero unschedule    Remove the daily schedule
  zero stop          Stop the local API server

USAGE
    ;;
esac
