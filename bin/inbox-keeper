#!/usr/bin/env bash
# bin/inbox-keeper — main CLI for inbox-keeper / mail-triage
set -euo pipefail

# Resolve repo root from this script's location, then source config.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=../config.sh
source "$SCRIPT_DIR/../config.sh"

SUBCOMMAND="${1:-}"

case "$SUBCOMMAND" in

  dashboard)
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file

    # Start keeper_server.py in the background if port 8765 is not already serving.
    if ! curl -s http://127.0.0.1:8765/ >/dev/null 2>&1; then
      echo "Starting keeper server..."
      "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/keeper_server.py" &
      # Give it a moment to start.
      sleep 1
    else
      echo "Keeper server already running."
    fi

    echo "Opening http://127.0.0.1:8765"
    open http://127.0.0.1:8765
    ;;

  app)
    APP_BUNDLE="$MAIL_TRIAGE_DIR/macapp/build/inbox-keeper.app"
    if [ ! -d "$APP_BUNDLE" ]; then
      echo "Building inbox-keeper.app (first run)..."
      bash "$MAIL_TRIAGE_DIR/macapp/build.sh"
    fi
    echo "Opening $APP_BUNDLE"
    open "$APP_BUNDLE"
    ;;

  run)
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file

    # Parse accounts.json (list OR {"accounts":[...]}) and run the keeper per account.
    accounts=$("$MAIL_TRIAGE_PYTHON" -c '
import json, sys
data = json.load(open(sys.argv[1]))
accts = data if isinstance(data, list) else data.get("accounts", [])
for a in accts:
    print("\t".join([a["config_dir"], a.get("email", a.get("slug", "")),
                     a.get("slug", a.get("email", ""))]))
' "$MAIL_TRIAGE_ACCOUNTS")

    while IFS=$'\t' read -r config_dir email slug; do
      [ -z "$config_dir" ] && continue
      echo "--- Running keeper pass for: $slug ($email) ---"
      "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/review_open_loops.py" \
        "$config_dir" "$email" --grace-days 2 --execute
    done <<< "$accounts"

    echo "--- Learning from recent actions ---"
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/learn.py" || true

    echo "--- Refreshing dashboard state ---"
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/dashboard_state.py"
    echo "Done."
    ;;

  state)
    export GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND=file
    echo "Refreshing dashboard state..."
    "$MAIL_TRIAGE_PYTHON" "$MAIL_TRIAGE_LIB/dashboard_state.py"
    echo "Done."
    ;;

  stop)
    if pkill -f keeper_server.py 2>/dev/null; then
      echo "Stopped keeper_server.py."
    else
      echo "No running keeper_server.py found."
    fi
    ;;

  schedule)
    # Install a LaunchAgent that runs the keeper every morning. Hour is arg 2 (default 7).
    HOUR="${2:-7}"
    LABEL="com.drewl.inbox-keeper.daily"
    PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
    mkdir -p "$HOME/Library/LaunchAgents" "$MAIL_TRIAGE_LOGS"
    cat > "$PLIST" <<PL
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>$LABEL</string>
  <key>ProgramArguments</key>
  <array>
    <string>$SCRIPT_DIR/inbox-keeper</string>
    <string>run</string>
  </array>
  <key>StartCalendarInterval</key>
  <dict><key>Hour</key><integer>$HOUR</integer><key>Minute</key><integer>0</integer></dict>
  <key>EnvironmentVariables</key>
  <dict><key>GOOGLE_WORKSPACE_CLI_KEYRING_BACKEND</key><string>file</string></dict>
  <key>StandardOutPath</key><string>$MAIL_TRIAGE_LOGS/daily.out.log</string>
  <key>StandardErrorPath</key><string>$MAIL_TRIAGE_LOGS/daily.err.log</string>
</dict>
</plist>
PL
    launchctl unload "$PLIST" 2>/dev/null || true
    if launchctl load -w "$PLIST" 2>/dev/null; then
      echo "Scheduled: the keeper runs daily at $(printf '%02d:00' "$HOUR"). Logs in $MAIL_TRIAGE_LOGS."
    else
      echo "Wrote $PLIST but couldn't load it; run: launchctl load -w \"$PLIST\""
    fi
    ;;

  unschedule)
    LABEL="com.drewl.inbox-keeper.daily"
    PLIST="$HOME/Library/LaunchAgents/$LABEL.plist"
    launchctl unload "$PLIST" 2>/dev/null || true
    rm -f "$PLIST"
    echo "Unscheduled the daily keeper."
    ;;

  *)
    cat <<'USAGE'
inbox-keeper — keep every inbox at "only what needs you"

Usage:
  inbox-keeper app           Build (if needed) and open the native menu-bar app
  inbox-keeper dashboard     Start the web panel and open it in your browser
  inbox-keeper run           Run the keeper across all accounts, then refresh state
  inbox-keeper state         Refresh the panel's data without opening anything
  inbox-keeper schedule [H]  Run the keeper automatically every morning (hour H, default 7)
  inbox-keeper unschedule    Remove the daily schedule
  inbox-keeper stop          Stop the local panel server

USAGE
    ;;
esac
