#!/usr/bin/env bash
# bin/release — tag and publish a new zero release
# Usage: bin/release <version>   e.g.  bin/release 1.2.0
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# ── 1. Argument check ────────────────────────────────────────────────────────
VERSION="${1:-}"
if [[ -z "$VERSION" ]]; then
  echo "Usage: bin/release <version>  (e.g. bin/release 1.2.0)" >&2
  exit 1
fi
TAG="v${VERSION}"

echo "==> Releasing zero ${TAG}"

# ── 2. Clean working tree on master ─────────────────────────────────────────
echo "==> Checking working tree..."
BRANCH="$(git -C "$REPO_ROOT" rev-parse --abbrev-ref HEAD)"
if [[ "$BRANCH" != "master" ]]; then
  echo "ERROR: must be on master (currently on '$BRANCH')." >&2
  exit 1
fi

if ! git -C "$REPO_ROOT" diff --quiet || ! git -C "$REPO_ROOT" diff --cached --quiet; then
  echo "ERROR: working tree is dirty. Commit or stash changes first." >&2
  exit 1
fi

# ── 3. Verify CHANGELOG has a section for this version ──────────────────────
CHANGELOG="$REPO_ROOT/CHANGELOG.md"
echo "==> Verifying CHANGELOG.md has a [${VERSION}] section..."
if ! grep -qE "^## \[${VERSION}\]" "$CHANGELOG"; then
  echo "ERROR: CHANGELOG.md has no '## [${VERSION}]' section." >&2
  echo "       Add release notes before running bin/release." >&2
  exit 1
fi

# ── 4. Build the app and DMG ─────────────────────────────────────────────────
echo "==> Building zero.app..."
bash "$REPO_ROOT/macapp/build.sh"

echo "==> Building zero.dmg..."
bash "$REPO_ROOT/macapp/make-dmg.sh"

DMG="$REPO_ROOT/macapp/build/zero.dmg"
if [[ ! -f "$DMG" ]]; then
  echo "ERROR: DMG not found at $DMG after build." >&2
  exit 1
fi

# ── 5. Extract release notes for this version ───────────────────────────────
echo "==> Extracting release notes for ${VERSION}..."
NOTES_FILE="$(mktemp /tmp/zero-release-notes.XXXXXX.md)"
trap 'rm -f "$NOTES_FILE"' EXIT

# Grab lines between ## [VERSION] and the next ## [ heading (exclusive).
awk "/^## \[${VERSION}\]/{found=1; next} found && /^## \[/{exit} found{print}" \
  "$CHANGELOG" > "$NOTES_FILE"

if [[ ! -s "$NOTES_FILE" ]]; then
  echo "ERROR: Could not extract notes for [${VERSION}] from CHANGELOG.md." >&2
  exit 1
fi

# Append a standard install footer so every release carries Gatekeeper guidance
# (zero is not yet Apple-notarized, so first launch needs the right-click/xattr step).
cat >> "$NOTES_FILE" <<'FOOTER'

## Installing

Requires macOS 26 (Tahoe, Apple Silicon). zero is signed ad-hoc, not notarized by
Apple, so a *downloaded* copy is quarantined and Gatekeeper refuses to launch it —
expected for a source-available app. The quarantine flag must be removed once.

**Easiest — one command does everything** (installs prerequisites, removes the
quarantine flag, launches):

```
curl -fsSL https://raw.githubusercontent.com/drewling/zero/master/macapp/install-zero.sh | bash
```

**By hand:** open the DMG, drag **zero** to Applications, then in Terminal:

```
/usr/bin/xattr -cr /Applications/zero.app
```

Use the full `/usr/bin/xattr` path — a Python or Homebrew `xattr` earlier in your
PATH may not support the recursive flag and will silently fail, leaving the app
blocked. (On macOS 26 the old right-click → Open trick no longer works for
ad-hoc-signed apps.)

Full setup (Google + Claude CLIs, first run) is in the [README](https://github.com/drewling/zero#install--first-run).
FOOTER

# ── 6. Create and push the tag ───────────────────────────────────────────────
echo "==> Creating tag ${TAG}..."
if git -C "$REPO_ROOT" rev-parse "$TAG" >/dev/null 2>&1; then
  echo "WARNING: tag ${TAG} already exists locally — skipping tag creation."
else
  git -C "$REPO_ROOT" tag -a "$TAG" -m "zero ${VERSION}"
fi

echo "==> Pushing tag ${TAG} to origin..."
git -C "$REPO_ROOT" push origin "$TAG"

# ── 7. Create GitHub release ─────────────────────────────────────────────────
echo "==> Creating GitHub release ${TAG}..."
RELEASE_URL="$(gh release create "$TAG" "$DMG" \
  --title "zero ${VERSION}" \
  --notes-file "$NOTES_FILE" \
  --repo drewling/zero)"

# ── 8. Install locally over /Applications ────────────────────────────────────
# bin/release only publishes the DMG; the user's running app stays stale until
# swapped. Do it here so every release lands in the app they actually use.
APP_SRC="$REPO_ROOT/macapp/build/zero.app"
APP_DST="/Applications/zero.app"
if [[ -d "$APP_SRC" ]]; then
  echo "==> Installing ${TAG} to ${APP_DST}..."
  osascript -e 'tell application "zero" to quit' >/dev/null 2>&1 || true
  pkill -x zero >/dev/null 2>&1 || true
  rm -rf "$APP_DST"
  cp -R "$APP_SRC" "$APP_DST"
  open "$APP_DST"
  echo "    Installed and relaunched."
else
  echo "WARNING: built app not found at $APP_SRC — skipped local install." >&2
fi

echo ""
echo "==> Done! Release published at:"
echo "    ${RELEASE_URL}"
