# config.env.example
# Copy to config.env, fill in the values, then:
#   source config.env && python app.py
# Or use a process supervisor (launchd, supervisor) that loads this file.

# Bot token — starts with xoxb-
# Required scopes: chat:write, chat:write.customize, im:write
SLACK_BOT_TOKEN=xoxb-YOUR-BOT-TOKEN-HERE

# App-level token — starts with xapp-
# Generate at api.slack.com/apps → Your App → Basic Information → App-Level Tokens
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-YOUR-APP-LEVEL-TOKEN-HERE

# Target for draft review cards.
# Use a channel ID (starts with C) to post to a channel, or a user ID
# (starts with U) to send yourself a DM.
SLACK_REVIEW_CHANNEL=C0123456789

# Optional: override the default queue.json path.
# QUEUE_PATH=/Users/user/mail-triage/drafts/queue.json
